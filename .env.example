# Environment configuration for your application

# Replace the placeholders below with your own secrets before running in production.

## Server runtime
PORT=3000
NODE_ENV=production

## Database and storage
DATABASE_URL=postgres://username:password@host:port/database
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

## Authentication
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret

## External services
BLUECONIC_API_KEY=your-blueconic-api-key
FIGMA_API_TOKEN=your-figma-api-token

## Third-party integrations
STRIPE_SECRET_KEY=your-stripe-secret-key
MAILGUN_API_KEY=your-mailgun-api-key

## Application metadata
APP_NAME=Your App
APP_URL=https://your-app.example.com

# End of environment configuration. Copy this file to .env and replace the placeholder values.
