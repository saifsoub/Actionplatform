# Copy this file to .env and replace the placeholder values.
# Generate unique values for SECRET_KEY, POSTGRES_PASSWORD, and FIRST_SUPERUSER_PASSWORD.

## Application
PROJECT_NAME=FastAPI Project
STACK_NAME=fastapi-project
DOMAIN=localhost.tiangolo.com
FRONTEND_HOST=http://localhost:5173
ENVIRONMENT=local
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

## Authentication
SECRET_KEY=changethis
ACCESS_TOKEN_EXPIRE_MINUTES=11520
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

## Database
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis
POSTGRES_DB=app

## AI council
ANTHROPIC_API_KEY=
COUNCIL_MODEL=claude-opus-4-6

## Email
SMTP_TLS=true
SMTP_SSL=false
SMTP_PORT=587
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
EMAILS_FROM_NAME=
EMAIL_RESET_TOKEN_EXPIRE_HOURS=48
EMAIL_TEST_USER=test@example.com

## Observability
SENTRY_DSN=

## Production images
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest

## Traefik dashboard for production deployments
EMAIL=admin@example.com
USERNAME=admin
HASHED_PASSWORD=changethis

## Frontend and end-to-end tests
VITE_API_URL=http://localhost:8000
MAILCATCHER_HOST=http://localhost:1080
CI=
